# ── xAI / Grok ────────────────────────────────────────────────────────────────
XAI_API_KEY=your_xai_api_key_here

# ── OpenAI (only required when using OpenAI embeddings) ──────────────────────
# OPENAI_API_KEY=your_openai_api_key_here

# ── Embedding model ───────────────────────────────────────────────────────────
# Default: local BAAI/bge-base-en-v1.5 (no API key required)
# To use OpenAI: set to "text-embedding-3-small" and provide OPENAI_API_KEY
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# ── Qdrant (local Docker — default) ──────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Qdrant Cloud (uncomment and fill in to use Qdrant Cloud instead) ─────────
# QDRANT_URL=https://<cluster-id>.us-east4-0.gcp.cloud.qdrant.io
# QDRANT_API_KEY=your_qdrant_cloud_api_key_here

# ── Collection name prefix ────────────────────────────────────────────────────
COLLECTION_NAME=contracts
